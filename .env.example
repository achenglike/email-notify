# SMTP 配置
SMTP_SERVER=smtp.163.com
SMTP_PORT=25
SENDER_MAIL=xxx@163.com
SENDER_PW=xxx

# API 鉴权（REST /api/send 与 MCP /mcp 共用同一个 token）
# 调用方需在 Authorization: Bearer 头里带上此值
API_KEY=change-me-to-a-long-random-string

# MCP 允许访问的 Host 头白名单（逗号分隔），用于 DNS rebinding 防护
# 默认只允许本机(127.0.0.1/localhost)；外部 AI 远程连接时需配置：
#   - 指定主机：MCP_ALLOWED_HOSTS=notify.example.com:*,10.0.0.5:*  （通配端口用 host:*）
#   - 全放开：  MCP_ALLOWED_HOSTS=*   （关闭 Host 校验，仅靠 Bearer Token 鉴权，适合 Docker/反代/内网）
MCP_ALLOWED_HOSTS=
